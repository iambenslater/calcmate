<%- include('partials/head') %>
<!-- WebPage schema for category -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "<%- categoryName.replace(/"/g, '\\"') %> Calculators",
  "description": "<%- categoryDescription.replace(/"/g, '\\"') %>",
  "url": "<%- siteUrl %>/<%- category %>",
  "isPartOf": { "@type": "WebSite", "name": "CalculatorMate Australia", "url": "<%- siteUrl %>" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "<%- siteUrl %>" },
      { "@type": "ListItem", "position": 2, "name": "<%- categoryName.replace(/"/g, '\\"') %>", "item": "<%- siteUrl %>/<%- category %>" }
    ]
  }
}
</script>
<%- include('partials/ad-hero-banner', { calc: { affiliateContext: calcs[0] ? calcs[0].affiliateContext : 'general' } }) %>
<%- include('partials/header') %>

<main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-6">
  <%- include('partials/breadcrumbs', { category, categoryName }) %>

  <div class="lg:flex gap-8">
    <!-- Main content -->
    <div class="flex-1">
      <div class="mb-8">
        <h1 class="text-3xl font-bold text-navy mb-2"><%= categoryIcon %> <%= categoryName %> Calculators</h1>
        <p class="text-gray-600"><%= categoryDescription %></p>
      </div>

      <% if (category === 'separation') { %>
      <div class="bg-blue-50 border border-blue-200 rounded-xl p-5 mb-8">
        <h2 class="font-semibold text-navy mb-2">📋 Official Government Resources</h2>
        <p class="text-sm text-gray-600 mb-3">These calculators provide estimates only. For official assessments, contact:</p>
        <div class="grid sm:grid-cols-2 gap-2 text-sm">
          <a href="https://www.servicesaustralia.gov.au/child-support" target="_blank" rel="noopener" class="flex items-center gap-2 text-blue-700 hover:underline">🏛️ Services Australia — Child Support</a>
          <a href="https://www.familyrelationships.gov.au" target="_blank" rel="noopener" class="flex items-center gap-2 text-blue-700 hover:underline">👨‍👩‍👧 Family Relationships Online</a>
          <a href="https://www.fcfcoa.gov.au" target="_blank" rel="noopener" class="flex items-center gap-2 text-blue-700 hover:underline">⚖️ Federal Circuit & Family Court</a>
          <a href="https://www.legalaid.nsw.gov.au" target="_blank" rel="noopener" class="flex items-center gap-2 text-blue-700 hover:underline">📞 Legal Aid (find your state)</a>
        </div>
        <p class="text-xs text-gray-500 mt-3">Free call: Family Relationship Advice Line <strong>1800 050 321</strong></p>
      </div>
      <% } %>

      <div class="grid sm:grid-cols-2 gap-4">
        <% calcs.forEach((c, idx) => { %>
          <a href="/<%= c.category %>/<%= c.slug %>" class="group bg-white rounded-xl p-5 shadow-sm hover:shadow-md border border-gray-100 hover:border-gold/50 transition">
            <h2 class="font-semibold text-navy group-hover:text-gold transition mb-1"><%= c.title %></h2>
            <p class="text-sm text-gray-500"><%= c.description %></p>
          </a>
          <% if (idx === 5) { %>
            <div class="sm:col-span-2">
              <ins class="adsbygoogle"
                style="display:block"
                data-ad-client="ca-pub-8414007005923504"
                data-ad-slot="7713696451"
                data-ad-format="auto"
                data-full-width-responsive="true"></ins>
              <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
            </div>
          <% } %>
        <% }) %>
      </div>

      <% if (catArticles && catArticles.length) { %>
      <section class="mt-10">
        <h2 class="text-2xl font-bold text-navy mb-4">📖 Articles & Guides</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          <% catArticles.forEach(a => { %>
            <a href="/articles/<%= a.slug %>" class="group bg-white rounded-xl p-5 shadow-sm hover:shadow-md border border-gray-100 hover:border-gold/50 transition">
              <h3 class="font-semibold text-sm text-navy group-hover:text-gold transition mb-2"><%= a.title %></h3>
              <p class="text-xs text-gray-500 line-clamp-2"><%= a.excerpt %></p>
              <span class="text-xs text-gold font-medium mt-2 inline-block"><%= a.readTime %> · Read more →</span>
            </a>
          <% }) %>
        </div>
      </section>
      <% } %>

      <!-- Editorial pick after calculator listing -->
      <div class="mt-8"><%- include('partials/ad-editorial-pick', { calc: { affiliateContext: calcs[0] ? calcs[0].affiliateContext : 'general' } }) %></div>

      <!-- Inline Amazon CTA -->
      <div class="mt-8"><%- include('partials/affiliate-inline', { calc: { affiliateContext: calcs[0] ? calcs[0].affiliateContext : 'general' } }) %></div>
    </div>

    <!-- Sidebar -->
    <aside class="w-full lg:w-72 mt-8 lg:mt-0 shrink-0">
      <div class="sticky top-20 space-y-4">
        <!-- AdSense sidebar -->
        <div>
          <ins class="adsbygoogle"
            style="display:block"
            data-ad-client="ca-pub-8414007005923504"
            data-ad-slot="8240310065"
            data-ad-format="auto"
            data-full-width-responsive="true"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
          <h3 class="font-semibold text-navy mb-3 text-sm uppercase tracking-wider">All Categories</h3>
          <nav class="space-y-1">
            <% Object.entries(categoryMeta).forEach(([key, meta]) => { %>
              <a href="/<%= key %>" class="block px-3 py-2 rounded-lg text-sm transition <%= key === category ? 'bg-gold-light text-navy font-medium' : 'hover:bg-gray-50 text-gray-600' %>">
                <span class="mr-2"><%= meta.icon %></span><%= meta.name %>
              </a>
            <% }) %>
          </nav>
        </div>

        <!-- Amazon product cards -->
        <%- include('partials/ad-product', { calc: { affiliateContext: calcs[0] ? calcs[0].affiliateContext : 'general' } }) %>
      </div>
    </aside>
  </div>
</main>

<%- include('partials/ad-footer-banner', { calc: { affiliateContext: calcs[0] ? calcs[0].affiliateContext : 'general' } }) %>
<%- include('partials/footer') %>
<%- include('partials/tail') %>
