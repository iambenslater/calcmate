<%- include('partials/head') %>
<%- include('partials/ad-hero-banner', { calc: { affiliateContext: 'general' } }) %>
<%- include('partials/header') %>

<main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-6">
  <nav aria-label="Breadcrumb" class="mb-4">
    <ol class="flex items-center gap-2 text-sm text-gray-500">
      <li><a href="/" class="hover:text-navy transition">Home</a></li>
      <li class="text-gray-300">/</li>
      <li class="text-gray-800 font-medium">Calculators For...</li>
    </ol>
  </nav>

  <h1 class="text-3xl font-bold text-navy mb-2">Calculators For...</h1>
  <p class="text-gray-600 mb-8">Find the right calculators for your situation. We've grouped our 100+ tools by life stage and need.</p>

  <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
    <% audiences.forEach(a => { %>
      <a href="/for/<%= a.slug %>" class="group bg-white rounded-xl p-6 shadow-sm hover:shadow-md border border-gray-100 hover:border-gray-300 transition">
        <div class="text-3xl mb-3"><%= a.icon || '👤' %></div>
        <h2 class="font-bold text-navy group-hover:text-gray-600 transition text-lg mb-2"><%= a.shortTitle || a.title %></h2>
        <p class="text-sm text-gray-500"><%= a.blurb %></p>
        <span class="text-xs text-gold font-medium mt-3 inline-block">View calculators →</span>
      </a>
    <% }) %>
  </div>
</main>

<%- include('partials/ad-footer-banner', { calc: { affiliateContext: 'general' } }) %>
<%- include('partials/footer') %>
<%- include('partials/tail') %>
