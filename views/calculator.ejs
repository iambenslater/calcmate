<%- include('partials/head') %>
<% if (calc.faq && calc.faq.length) { %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    <% calc.faq.forEach((f, i) => { %>
    {
      "@type": "Question",
      "name": "<%- f.q.replace(/"/g, '\\"') %>",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "<%- f.a.replace(/"/g, '\\"') %>"
      }
    }<%= i < calc.faq.length - 1 ? ',' : '' %>
    <% }) %>
  ]
}
</script>
<% } %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "<%- calc.title.replace(/"/g, '\\"') %>",
  "description": "<%- calc.description.replace(/"/g, '\\"') %>",
  "url": "<%- siteUrl %>/<%- calc.category %>/<%- calc.slug %>",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "All",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "AUD" },
  "publisher": { "@type": "Organization", "name": "CalculatorMate", "url": "<%- siteUrl %>" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "<%- calc.title.replace(/"/g, '\\"') %>",
  "description": "<%- (calc.metaDescription || calc.description).replace(/"/g, '\\"') %>",
  "url": "<%- siteUrl %>/<%- calc.category %>/<%- calc.slug %>",
  "isPartOf": { "@type": "WebSite", "name": "CalculatorMate Australia", "url": "<%- siteUrl %>" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "<%- siteUrl %>" },
      { "@type": "ListItem", "position": 2, "name": "<%- categoryName.replace(/"/g, '\\"') %>", "item": "<%- siteUrl %>/<%- calc.category %>" },
      { "@type": "ListItem", "position": 3, "name": "<%- calc.title.replace(/"/g, '\\"') %>", "item": "<%- siteUrl %>/<%- calc.category %>/<%- calc.slug %>" }
    ]
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".result-value"]
  }
}
</script>
<%- include('partials/ad-hero-banner') %>
<%- include('partials/header') %>

<main class="flex-1 max-w-6xl mx-auto w-full px-5 sm:px-8 py-8" data-calculator-slug="<%= calc.slug %>" data-affiliate-context="<%= calc.affiliateContext || calc.category %>">
  <%- include('partials/breadcrumbs', { category: calc.category, categoryName, calc }) %>

  <div class="lg:flex gap-10">
    <!-- Main content -->
    <div class="flex-1 min-w-0">
      <div class="mb-6">
        <p class="cm-gradient-text text-xs font-semibold uppercase tracking-widest mb-3"><%= categoryName %></p>
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 cm-heading mb-2"><%= calc.title %></h1>
        <p class="text-gray-500"><%= calc.description %></p>
      </div>

      <% if (calc.category === 'separation') { %>
      <!-- Government resources banner for separated parents calculators -->
      <div class="mb-6 p-5 bg-blue-50 border border-blue-100 rounded-2xl">
        <div class="flex items-start gap-3">
          <svg class="w-5 h-5 text-blue-600 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <div class="text-sm text-blue-900">
            <p class="font-semibold mb-1">This calculator provides estimates only. For official assessments, use these government resources:</p>
            <ul class="space-y-1 text-blue-800">
              <li><a href="https://www.servicesaustralia.gov.au/child-support" target="_blank" rel="noopener" class="underline hover:text-blue-600">Services Australia — Child Support</a></li>
              <li><a href="https://www.familyrelationships.gov.au" target="_blank" rel="noopener" class="underline hover:text-blue-600">Family Relationships Online</a> — free advice, mediation referrals (1800 050 321)</li>
              <li><a href="https://www.fcfcoa.gov.au" target="_blank" rel="noopener" class="underline hover:text-blue-600">Federal Circuit and Family Court of Australia</a></li>
              <li><a href="https://www.legalaid.nsw.gov.au/get-legal-help/family-law" target="_blank" rel="noopener" class="underline hover:text-blue-600">Legal Aid</a> — free or low-cost legal help (available in every state)</li>
            </ul>
          </div>
        </div>
      </div>
      <% } %>

      <!-- How it works — compact, above calculator for context -->
      <% if (calc.howItWorks) { %>
        <details class="mb-6 cm-card overflow-hidden">
          <summary class="cursor-pointer px-5 py-3 text-sm font-semibold text-gray-900 flex items-center gap-2 hover:bg-black/[0.02] transition rounded-2xl">
            <svg class="w-4 h-4 shrink-0" style="color: #BFA956" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            How this calculator works
            <svg class="w-3.5 h-3.5 ml-auto text-gray-400 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </summary>
          <div class="px-5 pb-4 pt-1 prose prose-xs max-w-none text-gray-600 text-xs leading-relaxed border-t border-black/5"><%- calc.howItWorks %></div>
        </details>
      <% } %>

      <!-- Calculator widget -->
      <div class="cm-card p-6 md:p-8 mb-8" id="calculator-widget">
        <div id="calc-inputs">
          <% if (calc.inputs && calc.inputs.length) { %>
            <% calc.inputs.forEach(input => { %>
              <div class="mb-4">
                <label for="input-<%= input.id %>" class="block text-sm font-medium text-gray-700 mb-1.5"><%= input.label %></label>
                <% if (input.type === 'select') { %>
                  <select id="input-<%= input.id %>" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-black/10 focus:border-gray-400 transition-all duration-200 text-sm">
                    <% (input.options || []).forEach(opt => { %>
                      <option value="<%= opt.value %>" <%= opt.default ? 'selected' : '' %>><%= opt.label %></option>
                    <% }) %>
                  </select>
                <% } else if (input.type === 'radio') { %>
                  <div class="flex flex-wrap gap-3">
                    <% const hasDefault = (input.options || []).some(o => o.default); %>
                    <% (input.options || []).forEach((opt, optIdx) => { %>
                      <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" name="input-<%= input.id %>" value="<%= opt.value %>" <%= opt.default || (!hasDefault && optIdx === 0) ? 'checked' : '' %> class="text-gray-900 focus:ring-gray-900">
                        <span class="text-sm"><%= opt.label %></span>
                      </label>
                    <% }) %>
                  </div>
                <% } else if (input.type === 'checkbox') { %>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" id="input-<%= input.id %>" <%= input.default ? 'checked' : '' %> class="rounded text-gray-900 focus:ring-gray-900">
                    <span class="text-sm"><%= input.checkLabel || '' %></span>
                  </label>
                <% } else if (input.type === 'range') { %>
                  <div class="flex items-center gap-4">
                    <input type="range" id="input-<%= input.id %>"
                      value="<%= typeof input.default !== 'undefined' ? input.default : (typeof input.min !== 'undefined' ? input.min : 0) %>"
                      <% if (typeof input.min !== 'undefined') { %>min="<%= input.min %>"<% } %>
                      <% if (typeof input.max !== 'undefined') { %>max="<%= input.max %>"<% } %>
                      <% if (input.step) { %>step="<%= input.step %>"<% } %>
                      class="flex-1 h-2 bg-gray-200 rounded-lg appearance-none cursor-pointer accent-gray-900"
                      oninput="document.getElementById('range-val-<%= input.id %>').textContent=this.value"
                    >
                    <span id="range-val-<%= input.id %>" class="min-w-[3rem] text-center text-lg font-bold text-gray-900 bg-gray-100 rounded-xl px-3 py-1"><%= typeof input.default !== 'undefined' ? input.default : (typeof input.min !== 'undefined' ? input.min : 0) %></span>
                  </div>
                  <div class="flex justify-between text-xs text-gray-400 mt-1">
                    <span><%= typeof input.min !== 'undefined' ? input.min : 0 %></span>
                    <span><%= typeof input.max !== 'undefined' ? input.max : 100 %></span>
                  </div>
                <% } else if (input.type === 'date') { %>
                  <input type="date" id="input-<%= input.id %>" value="<%= input.default || '' %>" class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-black/10 focus:border-gray-400 transition-all duration-200 text-sm">
                <% } else { %>
                  <div class="relative">
                    <% if (input.prefix) { %><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"><%= input.prefix %></span><% } %>
                    <input type="<%= input.type || 'number' %>" id="input-<%= input.id %>"
                      value="<%= typeof input.default !== 'undefined' ? input.default : '' %>"
                      placeholder="<%= input.placeholder || '' %>"
                      <% if (typeof input.min !== 'undefined') { %>min="<%= input.min %>"<% } %>
                      <% if (typeof input.max !== 'undefined') { %>max="<%= input.max %>"<% } %>
                      <% if (input.step) { %>step="<%= input.step %>"<% } %>
                      class="w-full px-4 py-2.5 rounded-xl border border-gray-200 bg-white focus:outline-none focus:ring-2 focus:ring-black/10 focus:border-gray-400 transition-all duration-200 text-sm <%= input.prefix ? 'pl-8' : '' %>"
                    >
                    <% if (input.suffix) { %><span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"><%= input.suffix %></span><% } %>
                  </div>
                <% } %>
                <% if (input.help) { %><p class="text-xs text-gray-400 mt-1"><%= input.help %></p><% } %>
              </div>
            <% }) %>
          <% } else { %>
            <p class="text-gray-500 text-sm italic">Calculator inputs loading...</p>
          <% } %>
        </div>

        <button id="calc-btn" class="w-full sm:w-auto mt-2 px-8 py-3 bg-gray-900 text-white font-semibold rounded-xl hover:bg-gray-800 transition-all duration-200 cm-shadow-soft hover:cm-shadow-md text-base">
          Calculate
        </button>

        <!-- Results -->
        <div id="calc-results" class="mt-8 hidden">
          <div class="bg-gradient-to-b from-gray-50 to-white rounded-2xl border border-black/5 p-6 md:p-8 cm-shadow-soft">
            <div class="flex items-center justify-between mb-5">
              <div class="flex items-center gap-2">
                <div class="w-1 h-6 rounded-full" style="background: #BFA956"></div>
                <h2 class="text-lg font-bold text-gray-900" style="letter-spacing: -0.02em;">Your Results</h2>
              </div>
              <span class="text-xs text-gray-400 font-medium">Rates current as of April 2026</span>
            </div>
            <div id="result-tldr" class="hidden mb-5 bg-gray-100 rounded-xl px-5 py-4">
              <p id="tldr-text" class="text-sm text-gray-700 leading-relaxed"></p>
            </div>
            <div id="results-content"></div>
          </div>
        </div>

      </div>

      <!-- AdSense post-results ad -->
      <div class="mb-8">
        <ins class="adsbygoogle"
          style="display:block; text-align:center;"
          data-ad-layout="in-article"
          data-ad-format="fluid"
          data-ad-client="ca-pub-8414007005923504"
          data-ad-slot="2652941462"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <!-- Editorial product pick — appears after results at peak engagement -->
      <%- include('partials/ad-editorial-pick') %>

      <!-- Ad: interstitial before FAQ -->
      <%- include('partials/affiliate-inline') %>

      <!-- FAQ -->
      <% if (calc.faq && calc.faq.length) { %>
        <div class="cm-card p-6 mb-8">
          <p class="cm-gradient-text text-xs font-semibold uppercase tracking-widest mb-3">FAQ</p>
          <h2 class="text-2xl font-bold text-gray-900 cm-heading mb-5">Frequently asked questions</h2>
          <div class="space-y-4">
            <% calc.faq.forEach((f, fIdx) => { %>
              <details class="group border-b border-gray-100 pb-3">
                <summary class="cursor-pointer font-medium text-gray-900 hover:text-gray-600 transition flex justify-between gap-2 text-sm sm:text-base leading-snug py-1">
                  <span class="flex-1"><%= f.q %></span>
                  <svg class="w-5 h-5 shrink-0 mt-0.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <p class="mt-2 text-sm text-gray-600 leading-relaxed"><%= f.a %></p>
              </details>
            <% }) %>
          </div>
        </div>
      <% } %>

      <!-- AdSense calculator ad -->
      <div class="mb-8">
        <ins class="adsbygoogle"
          style="display:block"
          data-ad-client="ca-pub-8414007005923504"
          data-ad-slot="7713696451"
          data-ad-format="auto"
          data-full-width-responsive="true"></ins>
        <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
      </div>

      <!-- Related calculators -->
      <% if (related && related.length) { %>
        <div class="mb-8">
          <p class="cm-gradient-text text-xs font-semibold uppercase tracking-widest mb-3">Related</p>
          <h2 class="text-2xl font-bold text-gray-900 cm-heading mb-4">Related calculators</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            <% related.forEach(r => { %>
              <a href="/<%= r.category %>/<%= r.slug %>" class="group cm-card p-5 hover:border-black/10 hover:-translate-y-0.5 transition-all duration-300">
                <h3 class="font-semibold text-gray-900 group-hover:text-gray-600 transition-colors duration-200 text-sm"><%= r.title %></h3>
                <p class="text-sm text-gray-500 mt-1.5"><%= r.description %></p>
                <span class="inline-flex items-center gap-1 text-xs font-medium text-gray-500 group-hover:text-gray-700 mt-3 transition-colors">
                  Open calculator
                  <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </span>
              </a>
            <% }) %>
          </div>
        </div>
      <% } %>

      <!-- Related articles -->
      <% const relatedArticles = (articles || []).filter(a => {
        const calcCats = [calc.category, calc.slug];
        const articleText = ((a.title || '') + ' ' + (a.excerpt || '') + ' ' + (a.metaDescription || '')).toLowerCase();
        const catKeywords = {
          'finance': ['tax', 'income', 'pay', 'salary', 'budget', 'saving'],
          'property': ['mortgage', 'home loan', 'stamp duty', 'property', 'house', 'borrowing', 'lmi'],
          'super': ['super', 'retirement', 'superannuation'],
          'car': ['car', 'vehicle', 'fuel', 'rego', 'driving'],
          'health': ['bmi', 'calorie', 'fitness', 'weight', 'health', 'pregnancy'],
          'business': ['leave', 'redundancy', 'hourly', 'overtime', 'business'],
          'advanced-finance': ['interest', 'loan', 'credit card', 'capital gains', 'offset', 'refinance'],
          'investment': ['rental', 'dividend', 'gearing', 'investment', 'crypto']
        };
        const keywords = catKeywords[calc.category] || [];
        return keywords.some(kw => articleText.includes(kw));
      }).slice(0, 4); %>
      <% if (relatedArticles.length) { %>
        <div class="mb-8">
          <p class="cm-gradient-text text-xs font-semibold uppercase tracking-widest mb-3">Learn</p>
          <h2 class="text-2xl font-bold text-gray-900 cm-heading mb-4">Related articles & guides</h2>
          <div class="grid sm:grid-cols-2 gap-4">
            <% relatedArticles.forEach(a => { %>
              <a href="/articles/<%= a.slug %>" class="group cm-card p-5 hover:border-black/10 hover:-translate-y-0.5 transition-all duration-300">
                <h3 class="font-semibold text-gray-900 group-hover:text-gray-600 transition-colors duration-200 text-sm"><%= a.title %></h3>
                <p class="text-sm text-gray-500 mt-1.5 line-clamp-2"><%= a.excerpt || a.metaDescription %></p>
                <span class="inline-flex items-center gap-1 text-xs font-medium text-gray-500 group-hover:text-gray-700 mt-3 transition-colors">
                  Read more
                  <svg class="w-3 h-3 group-hover:translate-x-0.5 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
                </span>
              </a>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Sidebar — sticky, no scroll -->
    <aside class="w-full lg:w-72 mt-8 lg:mt-0 shrink-0">
      <div class="sticky top-20 space-y-4">
        <!-- AdSense sidebar -->
        <div>
          <ins class="adsbygoogle"
            style="display:block"
            data-ad-client="ca-pub-8414007005923504"
            data-ad-slot="8240310065"
            data-ad-format="auto"
            data-full-width-responsive="true"></ins>
          <script>(adsbygoogle = window.adsbygoogle || []).push({});</script>
        </div>
        <!-- Share -->
        <%- include('partials/share') %>
        <!-- Category nav -->
        <div class="cm-card p-4">
          <h3 class="font-semibold text-gray-900 mb-3 text-sm"><%= categoryIcon %> <%= categoryName %></h3>
          <nav class="space-y-1">
            <% (calcsByCategory[calc.category] || []).forEach(c => { %>
              <a href="/<%= c.category %>/<%= c.slug %>" class="block px-3 py-1.5 rounded-lg text-xs transition-all duration-200 <%= c.slug === calc.slug ? 'bg-gray-100 text-gray-900 font-medium' : 'hover:bg-black/5 text-gray-600 hover:text-gray-900' %>">
                <%= c.title %>
              </a>
            <% }) %>
          </nav>
        </div>

        <!-- Amazon product cards (real products when available, search links as fallback) -->
        <%- include('partials/ad-product') %>
      </div>
    </aside>
  </div>
</main>

