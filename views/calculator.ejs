<!-- Results enhancement (charts, sharing, PDF) -->
<script src="/js/calcmate-results.js"></script>

<script>
  // TLDR rendering
  function renderTLDR() {
    var tldrBox = document.getElementById('result-tldr');
    var tldrText = document.getElementById('tldr-text');
    if (!tldrBox || !tldrText) return;
    if (typeof getTLDR === 'function') {
      try {
        var text = getTLDR();
        if (text) {
          tldrText.textContent = text;
          tldrBox.classList.remove('hidden');
          return;
        }
      } catch(e) {}
    }
    tldrBox.classList.add('hidden');
  }

  // Calculate button
  document.getElementById('calc-btn').addEventListener('click', function() {
    if (typeof calculate === 'function') {
      calculate();
      renderTLDR();
      if (typeof window.onCalculateComplete === 'function') window.onCalculateComplete();
      setTimeout(function() {
        var r = document.getElementById('calc-results');
        if (r) r.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  });

  // Real-time calculation as you type (debounced)
  (function() {
    var debounceTimer;
    var calcInputs = document.getElementById('calc-inputs');
    if (!calcInputs) return;
    calcInputs.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function() {
        if (typeof calculate === 'function' && !document.getElementById('calc-results').classList.contains('hidden')) {
          calculate();
          renderTLDR();
          if (typeof window.onCalculateComplete === 'function') window.onCalculateComplete();
        }
      }, 400);
    });
    calcInputs.addEventListener('change', function(e) {
      if (e.target.tagName === 'SELECT' || e.target.type === 'radio' || e.target.type === 'checkbox') {
        if (typeof calculate === 'function' && !document.getElementById('calc-results').classList.contains('hidden')) {
          calculate();
          renderTLDR();
          if (typeof window.onCalculateComplete === 'function') window.onCalculateComplete();
        }
      }
    });
  })();

  // Pre-fill from URL params (AI search or shareable links)
  (function() {
    var params = new URLSearchParams(window.location.search);
    if (!params.get('prefill')) return;
    var filled = false;
    params.forEach(function(value, key) {
      if (key === 'prefill') return;
      // Try number/text input
      var el = document.getElementById('input-' + key);
      if (el) {
        if (el.type === 'checkbox') {
          el.checked = (value === 'true' || value === '1' || value === 'yes');
        } else if (el.tagName === 'SELECT') {
          el.value = value;
        } else {
          el.value = value;
        }
        filled = true;
        return;
      }
      // Try radio
      var radio = document.querySelector('input[name="input-' + key + '"][value="' + value + '"]');
      if (radio) { radio.checked = true; filled = true; }
    });
    // Auto-calculate if we filled anything
    if (filled) {
      setTimeout(function() {
        if (typeof calculate === 'function') {
          calculate();
          if (typeof window.onCalculateComplete === 'function') window.onCalculateComplete();
          setTimeout(function() {
            var r = document.getElementById('calc-results');
            if (r) r.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }, 200);
        }
      }, 300);
    }
  })();
</script>
<%- include('partials/tail') %>
