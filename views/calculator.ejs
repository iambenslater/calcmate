<%- include('partials/head') %>
<% if (calc.faq && calc.faq.length) { %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    <% calc.faq.forEach((f, i) => { %>
    {
      "@type": "Question",
      "name": "<%- f.q.replace(/"/g, '\\"') %>",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "<%- f.a.replace(/"/g, '\\"') %>"
      }
    }<%= i < calc.faq.length - 1 ? ',' : '' %>
    <% }) %>
  ]
}
</script>
<% } %>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "<%= calc.title %>",
  "description": "<%= calc.description %>",
  "url": "<%= siteUrl %>/<%= calc.category %>/<%= calc.slug %>",
  "applicationCategory": "UtilityApplication",
  "operatingSystem": "All",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "AUD" },
  "publisher": { "@type": "Organization", "name": "CalculatorMate", "url": "<%= siteUrl %>" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "name": "<%= calc.title %>",
  "description": "<%= calc.metaDescription || calc.description %>",
  "url": "<%= siteUrl %>/<%= calc.category %>/<%= calc.slug %>",
  "isPartOf": { "@type": "WebSite", "name": "CalculatorMate Australia", "url": "<%= siteUrl %>" },
  "breadcrumb": {
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "<%= siteUrl %>" },
      { "@type": "ListItem", "position": 2, "name": "<%= categoryName %>", "item": "<%= siteUrl %>/<%= calc.category %>" },
      { "@type": "ListItem", "position": 3, "name": "<%= calc.title %>" }
    ]
  },
  "speakable": {
    "@type": "SpeakableSpecification",
    "cssSelector": ["h1", ".result-value"]
  }
}
</script>
<%- include('partials/header') %>

<!-- Header ad -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
  <% adSlotNum = (typeof adSlotNum === 'undefined') ? 0 : adSlotNum; %><%- include('partials/ad-leaderboard', { adSlot: adSlotNum++ }) %>
</div>

<main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-6">
  <%- include('partials/breadcrumbs', { category: calc.category, categoryName, calc }) %>

  <div class="lg:flex gap-8">
    <!-- Main content -->
    <div class="flex-1 min-w-0">
      <h1 class="text-3xl font-bold text-navy mb-2"><%= calc.title %></h1>
      <p class="text-gray-600 mb-4"><%= calc.description %></p>
      <%- include('partials/share') %>

      <!-- Calculator widget -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8" id="calculator-widget">
        <div id="calc-inputs">
          <% if (calc.inputs && calc.inputs.length) { %>
            <% calc.inputs.forEach(input => { %>
              <div class="mb-4">
                <label for="input-<%= input.id %>" class="block text-sm font-medium text-gray-700 mb-1"><%= input.label %></label>
                <% if (input.type === 'select') { %>
                  <select id="input-<%= input.id %>" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-gold focus:border-gold transition">
                    <% (input.options || []).forEach(opt => { %>
                      <option value="<%= opt.value %>" <%= opt.default ? 'selected' : '' %>><%= opt.label %></option>
                    <% }) %>
                  </select>
                <% } else if (input.type === 'radio') { %>
                  <div class="flex flex-wrap gap-3">
                    <% const hasDefault = (input.options || []).some(o => o.default); %>
                    <% (input.options || []).forEach((opt, optIdx) => { %>
                      <label class="flex items-center gap-2 cursor-pointer">
                        <input type="radio" name="input-<%= input.id %>" value="<%= opt.value %>" <%= opt.default || (!hasDefault && optIdx === 0) ? 'checked' : '' %> class="text-gold focus:ring-gold">
                        <span class="text-sm"><%= opt.label %></span>
                      </label>
                    <% }) %>
                  </div>
                <% } else if (input.type === 'checkbox') { %>
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" id="input-<%= input.id %>" <%= input.default ? 'checked' : '' %> class="rounded text-gold focus:ring-gold">
                    <span class="text-sm"><%= input.checkLabel || '' %></span>
                  </label>
                <% } else if (input.type === 'date') { %>
                  <input type="date" id="input-<%= input.id %>" value="<%= input.default || '' %>" class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-gold focus:border-gold transition">
                <% } else { %>
                  <div class="relative">
                    <% if (input.prefix) { %><span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"><%= input.prefix %></span><% } %>
                    <input type="<%= input.type || 'number' %>" id="input-<%= input.id %>"
                      value="<%= typeof input.default !== 'undefined' ? input.default : '' %>"
                      placeholder="<%= input.placeholder || '' %>"
                      <% if (typeof input.min !== 'undefined') { %>min="<%= input.min %>"<% } %>
                      <% if (typeof input.max !== 'undefined') { %>max="<%= input.max %>"<% } %>
                      <% if (input.step) { %>step="<%= input.step %>"<% } %>
                      class="w-full px-4 py-2.5 rounded-lg border border-gray-300 focus:outline-none focus:ring-2 focus:ring-gold focus:border-gold transition <%= input.prefix ? 'pl-8' : '' %>"
                    >
                    <% if (input.suffix) { %><span class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 text-sm"><%= input.suffix %></span><% } %>
                  </div>
                <% } %>
                <% if (input.help) { %><p class="text-xs text-gray-400 mt-1"><%= input.help %></p><% } %>
              </div>
            <% }) %>
          <% } else { %>
            <p class="text-gray-500 text-sm italic">Calculator inputs loading...</p>
          <% } %>
        </div>

        <button id="calc-btn" class="w-full sm:w-auto mt-2 px-8 py-3 bg-gold text-navy font-bold rounded-lg hover:bg-yellow-400 transition shadow-sm text-lg">
          Calculate
        </button>

        <!-- Results -->
        <div id="calc-results" class="mt-8 hidden">
          <div class="bg-gradient-to-b from-gray-50 to-white rounded-2xl border border-gray-100 p-6 md:p-8 shadow-sm">
            <div class="flex items-center justify-between mb-5">
              <div class="flex items-center gap-2">
                <div class="w-1 h-6 bg-gold rounded-full"></div>
                <h2 class="text-lg font-bold" style="color: #1d1d1f; letter-spacing: -0.02em;">Your Results</h2>
              </div>
              <span class="text-xs text-gray-400 font-medium">Rates current as of April 2026</span>
            </div>
            <div id="result-tldr" class="hidden mb-5 bg-navy/5 rounded-xl px-5 py-4 border border-navy/10">
              <p id="tldr-text" class="text-sm text-gray-700 leading-relaxed"></p>
            </div>
            <div id="results-content"></div>
          </div>
        </div>

        <!-- Chart -->
        <div id="chart-container" class="mt-6 hidden">
          <div class="bg-gray-50 rounded-2xl p-5 md:p-6 border border-gray-100" style="max-height: 380px;">
            <canvas id="calcmate-chart"></canvas>
          </div>
        </div>
      </div>

      <!-- Ad: interstitial after calculator -->
      <div class="mb-8"><% adSlotNum = (typeof adSlotNum === 'undefined') ? 0 : adSlotNum; %><%- include('partials/ad-leaderboard', { adSlot: adSlotNum++ }) %></div>

      <!-- How it works -->
      <% if (calc.howItWorks) { %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
          <h2 class="text-xl font-bold text-navy mb-3">How It Works</h2>
          <div class="prose prose-sm max-w-none text-gray-600"><%- calc.howItWorks %></div>
        </div>
      <% } %>

      <!-- Ad: interstitial between how-it-works and FAQ -->
      <%- include('partials/affiliate-inline') %>

      <!-- FAQ -->
      <% if (calc.faq && calc.faq.length) { %>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6 mb-8">
          <h2 class="text-xl font-bold text-navy mb-4">Frequently Asked Questions</h2>
          <div class="space-y-4">
            <% calc.faq.forEach((f, fIdx) => { %>
              <details class="group border-b border-gray-100 pb-3">
                <summary class="cursor-pointer font-medium hover:text-gold transition flex justify-between gap-2 text-sm sm:text-base leading-snug py-1" style="color: #00205B;">
                  <span class="flex-1" style="color: #00205B;"><%= f.q %></span>
                  <svg class="w-5 h-5 shrink-0 mt-0.5" style="color: #9ca3af;" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
                </summary>
                <p class="mt-2 text-sm leading-relaxed" style="color: #4b5563;"><%= f.a %></p>
              </details>
              <% if (fIdx === 1) { %>
                <!-- Ad: between FAQ items -->
                <div class="my-2"><% adSlotNum = (typeof adSlotNum === 'undefined') ? 0 : adSlotNum; %><%- include('partials/ad-leaderboard', { adSlot: adSlotNum++ }) %></div>
              <% } %>
            <% }) %>
          </div>
        </div>
      <% } %>

      <!-- Ad: interstitial before related -->
      <div class="mb-8"><% adSlotNum = (typeof adSlotNum === 'undefined') ? 0 : adSlotNum; %><%- include('partials/ad-leaderboard', { adSlot: adSlotNum++ }) %></div>

      <!-- Related calculators -->
      <% if (related && related.length) { %>
        <div class="mb-8">
          <h2 class="text-xl font-bold text-navy mb-4">Related Calculators</h2>
          <div class="grid sm:grid-cols-2 gap-3">
            <% related.forEach(r => { %>
              <a href="/<%= r.category %>/<%= r.slug %>" class="group bg-white rounded-lg p-4 shadow-sm hover:shadow-md border border-gray-100 hover:border-gold/50 transition">
                <h3 class="font-medium text-navy group-hover:text-gold transition text-sm"><%= r.title %></h3>
                <p class="text-xs text-gray-500 mt-1"><%= r.description %></p>
              </a>
            <% }) %>
          </div>
        </div>
      <% } %>

      <!-- Related articles -->
      <% const relatedArticles = (articles || []).filter(a => {
        const calcCats = [calc.category, calc.slug];
        const articleText = ((a.title || '') + ' ' + (a.excerpt || '') + ' ' + (a.metaDescription || '')).toLowerCase();
        const catKeywords = {
          'finance': ['tax', 'income', 'pay', 'salary', 'budget', 'saving'],
          'property': ['mortgage', 'home loan', 'stamp duty', 'property', 'house', 'borrowing', 'lmi'],
          'super': ['super', 'retirement', 'superannuation'],
          'car': ['car', 'vehicle', 'fuel', 'rego', 'driving'],
          'health': ['bmi', 'calorie', 'fitness', 'weight', 'health', 'pregnancy'],
          'business': ['leave', 'redundancy', 'hourly', 'overtime', 'business'],
          'advanced-finance': ['interest', 'loan', 'credit card', 'capital gains', 'offset', 'refinance'],
          'investment': ['rental', 'dividend', 'gearing', 'investment', 'crypto']
        };
        const keywords = catKeywords[calc.category] || [];
        return keywords.some(kw => articleText.includes(kw));
      }).slice(0, 4); %>
      <% if (relatedArticles.length) { %>
        <div class="mb-8">
          <h2 class="text-xl font-bold text-navy mb-4">Related Articles & Guides</h2>
          <div class="grid sm:grid-cols-2 gap-3">
            <% relatedArticles.forEach(a => { %>
              <a href="/articles/<%= a.slug %>" class="group bg-white rounded-lg p-4 shadow-sm hover:shadow-md border border-gray-100 hover:border-gold/50 transition">
                <h3 class="font-medium text-navy group-hover:text-gold transition text-sm"><%= a.title %></h3>
                <p class="text-xs text-gray-500 mt-1 line-clamp-2"><%= a.excerpt || a.metaDescription %></p>
                <span class="text-xs text-gold font-medium mt-2 inline-block">Read more →</span>
              </a>
            <% }) %>
          </div>
        </div>
      <% } %>
    </div>

    <!-- Sidebar — sticky, no scroll -->
    <aside class="w-full lg:w-72 mt-8 lg:mt-0 shrink-0">
      <div class="sticky top-20 space-y-4">
        <!-- Category nav -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-4">
          <h3 class="font-semibold text-navy mb-3 text-sm uppercase tracking-wider"><%= categoryIcon %> <%= categoryName %></h3>
          <nav class="space-y-1">
            <% (calcsByCategory[calc.category] || []).forEach(c => { %>
              <a href="/<%= c.category %>/<%= c.slug %>" class="block px-3 py-1.5 rounded-lg text-xs transition <%= c.slug === calc.slug ? 'bg-gold-light text-navy font-medium' : 'hover:bg-gray-50 text-gray-600' %>">
                <%= c.title %>
              </a>
            <% }) %>
          </nav>
        </div>

        <!-- Amazon product cards (real products when available, search links as fallback) -->
        <%- include('partials/ad-product') %>
      </div>
    </aside>
  </div>
</main>

<!-- Footer ad -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-4">
  <% adSlotNum = (typeof adSlotNum === 'undefined') ? 0 : adSlotNum; %><%- include('partials/ad-leaderboard', { adSlot: adSlotNum++ }) %>
</div>

<%- include('partials/footer') %>

<!-- Expose calc data for results enhancement -->
<script>
  window._calcInputs = <%- JSON.stringify(calc.inputs || []) %>;
  window._calcSlug = '<%= calc.slug %>';
  window._calcCategory = '<%= calc.category %>';
  window._calcTitle = '<%= calc.title %>';
  window._chartConfig = <%- JSON.stringify(calc.chartConfig || null) %>;
</script>

<!-- Load calculator-specific JS -->
<script src="/js/calculators/<%= calc.slug %>.js?v=20260412t"></script>

<!-- Results enhancement (charts, sharing, PDF) -->
<script src="/js/calcmate-results.js"></script>

<script>
  // TLDR rendering
  function renderTLDR() {
    var tldrBox = document.getElementById('result-tldr');
    var tldrText = document.getElementById('tldr-text');
    if (!tldrBox || !tldrText) return;
    if (typeof getTLDR === 'function') {
      try {
        var text = getTLDR();
        if (text) {
          tldrText.textContent = text;
          tldrBox.classList.remove('hidden');
          return;
        }
      } catch(e) {}
    }
    tldrBox.classList.add('hidden');
  }

  // Calculate button
  document.getElementById('calc-btn').addEventListener('click', function() {
    if (typeof calculate === 'function') {
      calculate();
      renderTLDR();
      if (typeof window.onCalculateComplete === 'function') window.onCalculateComplete();
      setTimeout(function() {
        var r = document.getElementById('calc-results');
        if (r) r.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 100);
    }
  });

  // Real-time calculation as you type (debounced)
  (function() {
    var debounceTimer;
    var calcInputs = document.getElementById('calc-inputs');
    if (!calcInputs) return;
    calcInputs.addEventListener('input', function() {
      clearTimeout(debounceTimer);
      debounceTimer = setTimeout(function() {
        if (typeof calculate === 'function' && !document.getElementById('calc-results').classList.contains('hidden')) {
          calculate();
          renderTLDR();
          if (typeof window.onCalculateComplete === 'function') window.onCalculateComplete();
        }
      }, 400);
    });
    calcInputs.addEventListener('change', function(e) {
      if (e.target.tagName === 'SELECT' || e.target.type === 'radio' || e.target.type === 'checkbox') {
        if (typeof calculate === 'function' && !document.getElementById('calc-results').classList.contains('hidden')) {
          calculate();
          renderTLDR();
          if (typeof window.onCalculateComplete === 'function') window.onCalculateComplete();
        }
      }
    });
  })();

  // Pre-fill from URL params (AI search or shareable links)
  (function() {
    var params = new URLSearchParams(window.location.search);
    if (!params.get('prefill')) return;
    var filled = false;
    params.forEach(function(value, key) {
      if (key === 'prefill') return;
      // Try number/text input
      var el = document.getElementById('input-' + key);
      if (el) {
        if (el.type === 'checkbox') {
          el.checked = (value === 'true' || value === '1' || value === 'yes');
        } else if (el.tagName === 'SELECT') {
          el.value = value;
        } else {
          el.value = value;
        }
        filled = true;
        return;
      }
      // Try radio
      var radio = document.querySelector('input[name="input-' + key + '"][value="' + value + '"]');
      if (radio) { radio.checked = true; filled = true; }
    });
    // Auto-calculate if we filled anything
    if (filled) {
      setTimeout(function() {
        if (typeof calculate === 'function') {
          calculate();
          if (typeof window.onCalculateComplete === 'function') window.onCalculateComplete();
          setTimeout(function() {
            var r = document.getElementById('calc-results');
            if (r) r.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }, 200);
        }
      }, 300);
    }
  })();
</script>
<%- include('partials/tail') %>
