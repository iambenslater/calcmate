<%- include('partials/head') %>
<!-- Organization schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CalculatorMate",
  "url": "<%= siteUrl %>",
  "description": "100+ free online calculators built for Australians. Tax, mortgage, health, business calculators with current ATO rates and state-specific data.",
  "logo": {
    "@type": "ImageObject",
    "url": "<%= siteUrl %>/images/og-default.png",
    "width": 1200,
    "height": 630
  },
  "areaServed": { "@type": "Country", "name": "Australia" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CalculatorMate Australia",
  "url": "<%= siteUrl %>",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "<%= siteUrl %>/api/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
<%- include('partials/header') %>

<!-- Header ad -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pt-4">
  <% adSlotNum = 0; %><%- include('partials/ad-leaderboard', { adSlot: adSlotNum++ }) %>
</div>

<main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-6">

  <!-- Hero -->
  <section class="text-center py-12 md:py-16">
    <h1 class="text-4xl md:text-5xl font-bold text-navy mb-4">Your Calculation <span class="text-gold">Mate</span></h1>
    <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">121 free online calculators built for Australians. Tax, mortgage, health, business — all with current rates and state-specific data.</p>
    <div class="max-w-xl mx-auto relative">
      <input type="search" id="hero-search" placeholder="Search or ask a question..." class="w-full px-6 py-4 rounded-xl border-2 border-gray-200 text-lg focus:outline-none focus:border-gold focus:ring-2 focus:ring-gold/20 shadow-sm transition" autocomplete="off" maxlength="500">
      <div id="hero-search-results" class="absolute top-full left-0 right-0 mt-2 bg-white rounded-xl shadow-xl hidden max-h-80 overflow-y-auto z-50 border border-gray-100"></div>
    </div>
    <p id="hero-hint" class="text-sm text-gray-400 mt-3">Try "stamp duty" or ask "What's my take-home pay on $85k in NSW?"</p>
    <div class="max-w-xl mx-auto">
      <div id="ai-results" class="mt-4 hidden"></div>
      <div id="ai-loading" class="mt-4 hidden text-center">
        <div class="inline-flex items-center gap-2 text-gray-500 text-sm">
          <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg>
          Thinking...
        </div>
      </div>
    </div>
  </section>

  <!-- Categories -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-navy mb-6">Browse by Category</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      <% Object.entries(categoryMeta).forEach(([key, meta]) => { %>
        <% const count = (calcsByCategory[key] || []).length; %>
        <a href="/<%= key %>" class="group bg-white rounded-xl p-4 shadow-sm hover:shadow-md border border-gray-100 hover:border-gold/50 transition text-center">
          <div class="text-3xl mb-2"><%= meta.icon %></div>
          <h3 class="font-semibold text-sm text-navy group-hover:text-gold transition"><%= meta.name %></h3>
          <p class="text-xs text-gray-400 mt-1"><%= count %> calculators</p>
        </a>
      <% }) %>
    </div>
  </section>

  <!-- Ad: between categories and popular -->
  <div class="mb-12"><%- include('partials/ad-leaderboard', { adSlot: adSlotNum++ }) %></div>

  <!-- Popular -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-navy mb-6">Most Popular</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% popular.forEach((c, idx) => { %>
        <% const catMeta = categoryMeta[c.category] || {}; %>
        <a href="/<%= c.category %>/<%= c.slug %>" class="group bg-white rounded-xl p-5 shadow-sm hover:shadow-md border border-gray-100 hover:border-gold/50 transition">
          <div class="flex items-start gap-3">
            <span class="text-2xl"><%= catMeta.icon || '' %></span>
            <div>
              <h3 class="font-semibold text-navy group-hover:text-gold transition"><%= c.title %></h3>
              <p class="text-sm text-gray-500 mt-1"><%= c.description %></p>
            </div>
          </div>
        </a>
        <% if (idx === 5) { %>
          <!-- Ad: mid-popular inline -->
          <div class="sm:col-span-2 lg:col-span-3"><%- include('partials/ad-leaderboard', { adSlot: adSlotNum++ }) %></div>
        <% } %>
      <% }) %>
    </div>
  </section>

  <!-- Trending This Month -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-navy mb-2">Trending This Month</h2>
    <p class="text-sm text-gray-500 mb-5">The calculators Australians are using most right now</p>
    <div class="flex gap-3 overflow-x-auto pb-2 -mx-1 px-1 snap-x">
      <%
        const trending = [
          { slug: 'take-home-pay', category: 'finance', reason: 'Tax season prep' },
          { slug: 'mortgage-repayment', category: 'property', reason: 'Rate changes' },
          { slug: 'stamp-duty-all-states', category: 'property', reason: 'Property market' },
          { slug: 'super-balance-growth', category: 'super', reason: 'End of FY' },
          { slug: 'income-tax', category: 'finance', reason: 'New tax brackets' },
          { slug: 'borrowing-power', category: 'property', reason: 'Rate decisions' },
          { slug: 'gst-calculator', category: 'conversions', reason: 'BAS season' },
          { slug: 'budget-planner', category: 'finance', reason: 'Cost of living' }
        ];
      %>
      <% trending.forEach(t => { %>
        <% const tc = calculators.find(c => c.slug === t.slug); %>
        <% if (tc) { %>
          <a href="/<%= tc.category %>/<%= tc.slug %>" class="flex-shrink-0 w-56 snap-start group bg-white rounded-xl p-4 shadow-sm hover:shadow-md border border-gray-100 hover:border-gold/50 transition">
            <span class="inline-block text-xs font-medium text-gold bg-gold-light px-2 py-0.5 rounded-full mb-2"><%= t.reason %></span>
            <h3 class="font-semibold text-sm text-navy group-hover:text-gold transition"><%= tc.title %></h3>
            <p class="text-xs text-gray-500 mt-1 line-clamp-2"><%= tc.description %></p>
          </a>
        <% } %>
      <% }) %>
    </div>
  </section>

  <!-- Latest Articles -->
  <% if (articles && articles.length) { %>
  <section class="mb-12">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-2xl font-bold text-navy">Latest Articles & Guides</h2>
      <a href="/articles" class="text-sm text-gold font-medium hover:underline">View all →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% articles.slice(0, 6).forEach(a => { %>
        <a href="/articles/<%= a.slug %>" class="group bg-white rounded-xl p-5 shadow-sm hover:shadow-md border border-gray-100 hover:border-gold/50 transition">
          <h3 class="font-semibold text-sm text-navy group-hover:text-gold transition mb-2"><%= a.title %></h3>
          <p class="text-xs text-gray-500 line-clamp-2"><%= a.excerpt || a.metaDescription %></p>
          <span class="text-xs text-gold font-medium mt-3 inline-block">Read more →</span>
        </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <!-- Amazon featured products -->
  <%- include('partials/affiliate-inline', { calc: { affiliateContext: 'finance-books' } }) %>

  <!-- Ad: before all calculators -->
  <div class="mb-8"><%- include('partials/ad-leaderboard', { adSlot: adSlotNum++ }) %></div>

  <!-- All calculators for SEO -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold text-navy mb-6">All Calculators</h2>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <% Object.entries(categoryMeta).forEach(([key, meta]) => { %>
        <% const calcs = calcsByCategory[key] || []; %>
        <div class="mb-6 last:mb-0">
          <h3 class="font-semibold text-navy mb-2"><%= meta.icon %> <%= meta.name %></h3>
          <div class="flex flex-wrap gap-2">
            <% calcs.forEach(c => { %>
              <a href="/<%= c.category %>/<%= c.slug %>" class="text-sm px-3 py-1 rounded-full bg-gray-50 hover:bg-gold-light hover:text-navy transition border border-gray-200 hover:border-gold/50"><%= c.title %></a>
            <% }) %>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

</main>

<!-- Footer ad -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-4">
  <%- include('partials/ad-leaderboard', { adSlot: adSlotNum++ }) %>
</div>

<%- include('partials/footer') %>
<script src="/js/ai-search.js?v=20260412f"></script>
<%- include('partials/tail') %>
