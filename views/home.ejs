<%- include('partials/head') %>
<!-- Organization schema -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "CalculatorMate",
  "url": "<%- siteUrl %>",
  "description": "100+ free online calculators built for Australians. Tax, mortgage, health, business calculators with current ATO rates and state-specific data.",
  "logo": {
    "@type": "ImageObject",
    "url": "<%- siteUrl %>/images/og-default.png",
    "width": 1200,
    "height": 630
  },
  "areaServed": { "@type": "Country", "name": "Australia" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "CalculatorMate Australia",
  "url": "<%- siteUrl %>",
  "potentialAction": {
    "@type": "SearchAction",
    "target": "<%- siteUrl %>/api/search?q={search_term_string}",
    "query-input": "required name=search_term_string"
  }
}
</script>
<%- include('partials/header') %>

<main class="flex-1 max-w-7xl mx-auto w-full px-4 sm:px-6 lg:px-8 py-6">

  <!-- Hero -->
  <section class="text-center py-12 md:py-16">
    <h1 class="text-4xl md:text-5xl font-bold text-navy mb-4">Your Calculation <span class="text-gold">Mate</span></h1>
    <p class="text-lg text-gray-600 mb-8 max-w-2xl mx-auto">145 free online calculators built for Australians. Tax, mortgage, health, business — all with current rates and state-specific data.</p>
    <div class="max-w-2xl mx-auto relative">
      <div class="relative">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="absolute left-4 top-1/2 -translate-y-1/2 w-6 h-6 pointer-events-none"><rect width="32" height="32" rx="6" fill="#1a1a1a"/><rect x="5" y="5" width="22" height="22" rx="3" fill="#FFB800"/><rect x="8" y="8" width="16" height="5" rx="1" fill="#1a1a1a" opacity="0.9"/><rect x="8" y="15" width="4" height="4" rx="0.5" fill="#1a1a1a" opacity="0.7"/><rect x="14" y="15" width="4" height="4" rx="0.5" fill="#1a1a1a" opacity="0.7"/><rect x="20" y="15" width="4" height="4" rx="0.5" fill="#1a1a1a" opacity="0.7"/><rect x="8" y="21" width="4" height="4" rx="0.5" fill="#1a1a1a" opacity="0.7"/><rect x="14" y="21" width="4" height="4" rx="0.5" fill="#1a1a1a" opacity="0.7"/><rect x="20" y="21" width="4" height="4" rx="0.5" fill="#FFB800" stroke="#1a1a1a" stroke-width="0.5"/><text x="24" y="24.5" font-size="4" font-weight="bold" fill="#1a1a1a" text-anchor="middle" font-family="sans-serif">=</text></svg>
        <div id="rotating-placeholder" class="absolute left-14 top-1/2 -translate-y-1/2 pointer-events-none overflow-hidden h-7 flex items-center">
          <span id="rotating-text" class="text-gray-400 text-lg transition-all duration-500 ease-in-out"></span>
        </div>
        <input type="search" id="hero-search" class="w-full pl-14 pr-6 py-4 rounded-2xl border-2 border-gray-200 text-lg focus:outline-none focus:border-gold focus:ring-4 focus:ring-gold/10 shadow-md hover:shadow-lg transition bg-white" autocomplete="off" maxlength="500">
      </div>
      <div id="hero-search-results" class="absolute top-full left-0 right-0 mt-2 bg-white rounded-2xl shadow-2xl hidden max-h-96 overflow-y-auto z-50 border border-gray-100"></div>
    </div>
    <p id="hero-hint" class="text-sm text-gray-400 mt-3 hidden"></p>
    <div class="max-w-xl mx-auto">
      <div id="ai-results" class="mt-4 hidden"></div>
      <div id="ai-loading" class="mt-4 hidden text-center">
        <div class="inline-flex items-center gap-2 text-gray-500 text-sm">
          <svg class="animate-spin h-4 w-4" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"/><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"/></svg>
          Thinking...
        </div>
      </div>
    </div>

    <!-- Trending pills — above the fold, drives traffic to high-value calculator pages -->
    <%
      const trendingPills = [
        { slug: 'take-home-pay', category: 'finance', label: 'Tax Time 2026', icon: '🧾' },
        { slug: 'mortgage-repayment', category: 'property', label: 'What will I repay?', icon: '🏠' },
        { slug: 'borrowing-power', category: 'property', label: 'What can I borrow?', icon: '💰' },
        { slug: 'bmi', category: 'health', label: 'Am I a healthy weight?', icon: '⚖️' },
        { slug: 'stamp-duty-all-states', category: 'property', label: 'Stamp duty by state', icon: '📋' },
        { slug: 'compound-interest', category: 'finance', label: 'Grow my savings', icon: '📈' },
        { slug: 'calorie-intake', category: 'health', label: 'Daily calories', icon: '🍎' },
        { slug: 'budget-planner', category: 'finance', label: 'Build a budget', icon: '📊' },
        { slug: 'gst-calculator', category: 'conversions', label: 'BAS season', icon: '🧮' },
        { slug: 'fuel-cost', category: 'car', label: 'Trip fuel cost', icon: '⛽' }
      ];
    %>
    <div class="flex flex-wrap justify-center gap-2 mt-6 max-w-3xl mx-auto">
      <% trendingPills.forEach(t => { %>
        <a href="/<%= t.category %>/<%= t.slug %>" class="inline-flex items-center gap-1.5 px-4 py-2 bg-white rounded-full border border-gray-200 hover:border-gray-300 hover:bg-gray-100 text-sm font-medium text-gray-700 hover:text-gray-900 shadow-sm hover:shadow transition">
          <span><%= t.icon %></span>
          <span><%= t.label %></span>
        </a>
      <% }) %>
    </div>
  </section>

  <!-- Categories -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-navy mb-6">Browse by Category</h2>
    <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-5 gap-4">
      <% Object.entries(categoryMeta).forEach(([key, meta]) => { %>
        <% const count = (calcsByCategory[key] || []).length; %>
        <a href="/<%= key %>" class="group bg-white rounded-xl p-4 shadow-sm hover:shadow-md border border-gray-100 hover:border-gray-300 transition text-center">
          <div class="text-3xl mb-2"><%= meta.icon %></div>
          <h3 class="font-semibold text-sm text-navy group-hover:text-gray-600 transition"><%= meta.name %></h3>
          <p class="text-xs text-gray-400 mt-1"><%= count %> calculators</p>
        </a>
      <% }) %>
    </div>
  </section>

  <!-- Editorial pick — between categories and popular -->
  <div class="mb-12"><%- include('partials/ad-editorial-pick', { calc: { affiliateContext: 'finance-books' } }) %></div>

  <!-- Popular -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-navy mb-6">Most Popular</h2>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% popular.forEach((c, idx) => { %>
        <% const catMeta = categoryMeta[c.category] || {}; %>
        <a href="/<%= c.category %>/<%= c.slug %>" class="group bg-white rounded-xl p-5 shadow-sm hover:shadow-md border border-gray-100 hover:border-gray-300 transition">
          <div class="flex items-start gap-3">
            <span class="text-2xl"><%= catMeta.icon || '' %></span>
            <div>
              <h3 class="font-semibold text-navy group-hover:text-gray-600 transition"><%= c.title %></h3>
              <p class="text-sm text-gray-500 mt-1"><%= c.description %></p>
            </div>
          </div>
        </a>
      <% }) %>
    </div>
  </section>

  <!-- Latest Articles -->
  <% if (articles && articles.length) { %>
  <section class="mb-12">
    <div class="flex items-center justify-between mb-5">
      <h2 class="text-2xl font-bold text-navy">Latest Articles & Guides</h2>
      <a href="/articles" class="text-sm text-gold font-medium hover:underline">View all →</a>
    </div>
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
      <% articles.slice(0, 6).forEach(a => { %>
        <a href="/articles/<%= a.slug %>" class="group bg-white rounded-xl p-5 shadow-sm hover:shadow-md border border-gray-100 hover:border-gray-300 transition">
          <h3 class="font-semibold text-sm text-navy group-hover:text-gray-600 transition mb-2"><%= a.title %></h3>
          <p class="text-xs text-gray-500 line-clamp-2"><%= a.excerpt || a.metaDescription %></p>
          <span class="text-xs text-gold font-medium mt-3 inline-block">Read more →</span>
        </a>
      <% }) %>
    </div>
  </section>
  <% } %>

  <!-- Amazon featured products -->
  <%- include('partials/affiliate-inline', { calc: { affiliateContext: 'finance-books' } }) %>

  <!-- All calculators for SEO -->
  <section class="mb-8">
    <h2 class="text-2xl font-bold text-navy mb-6">All Calculators</h2>
    <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
      <% Object.entries(categoryMeta).forEach(([key, meta]) => { %>
        <% const calcs = calcsByCategory[key] || []; %>
        <div class="mb-6 last:mb-0">
          <h3 class="font-semibold text-navy mb-2"><a href="/<%= key %>" class="hover:text-gray-600 transition"><%= meta.icon %> <%= meta.name %></a></h3>
          <div class="flex flex-wrap gap-2">
            <% calcs.forEach(c => { %>
              <a href="/<%= c.category %>/<%= c.slug %>" class="text-sm px-3 py-1 rounded-full bg-gray-50 hover:bg-gray-100 hover:text-gray-900 transition border border-gray-200 hover:border-gray-300"><%= c.title %></a>
            <% }) %>
          </div>
        </div>
      <% }) %>
    </div>
  </section>

</main>

<%- include('partials/ad-footer-banner', { calc: { affiliateContext: 'general' } }) %>
<%- include('partials/footer') %>
<script src="/js/ai-search.js?v=20260412f"></script>
<script>
(function() {
  var suggestions = [
    'What\u2019s my take-home pay on $85k?',
    'How much stamp duty in NSW?',
    'What can I borrow for a mortgage?',
    'How much super should I have at 40?',
    'What\u2019s the GST on $500?',
    'How many calories should I eat?',
    'What are my mortgage repayments?',
    'Am I a healthy weight?',
    'How much does my coffee habit cost?',
    'What\u2019s my BMI?'
  ];
  var idx = 0;
  var el = document.getElementById('rotating-text');
  var ph = document.getElementById('rotating-placeholder');
  var input = document.getElementById('hero-search');
  if (!el || !input) return;

  function show() {
    if (input.value.length > 0 || document.activeElement === input) {
      ph.style.opacity = '0';
      return;
    }
    ph.style.opacity = '1';
    // Fade out
    el.style.opacity = '0';
    el.style.transform = 'translateY(-8px)';
    setTimeout(function() {
      el.textContent = suggestions[idx];
      idx = (idx + 1) % suggestions.length;
      // Fade in from below
      el.style.transform = 'translateY(8px)';
      // Force reflow
      el.offsetHeight;
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
    }, 400);
  }

  // Initial display
  el.textContent = suggestions[0];
  el.style.opacity = '1';
  idx = 1;

  // Rotate every 3.5 seconds
  setInterval(show, 3500);

  // Hide placeholder when user types or focuses
  input.addEventListener('input', function() {
    ph.style.opacity = input.value.length > 0 ? '0' : '1';
  });
  input.addEventListener('focus', function() { ph.style.opacity = '0'; });
  input.addEventListener('blur', function() {
    if (input.value.length === 0) { ph.style.opacity = '1'; }
  });
})();
</script>
<%- include('partials/tail') %>
