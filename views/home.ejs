<script src="/js/ai-search.js?v=20260412f"></script>
<script>
// Rotating placeholder
(function() {
  var suggestions = [
    'What\u2019s my take-home pay on $85k?',
    'How much stamp duty in NSW?',
    'What can I borrow for a mortgage?',
    'How much super should I have at 40?',
    'What\u2019s the GST on $500?',
    'How many calories should I eat?',
    'What are my mortgage repayments?',
    'Am I a healthy weight?',
    'How much does my coffee habit cost?',
    'What\u2019s my BMI?'
  ];
  var idx = 0;
  var el = document.getElementById('rotating-text');
  var ph = document.getElementById('rotating-placeholder');
  var input = document.getElementById('hero-search');
  if (!el || !input) return;
  function show() {
    if (input.value.length > 0 || document.activeElement === input) { ph.style.opacity = '0'; return; }
    ph.style.opacity = '1';
    el.style.opacity = '0';
    el.style.transform = 'translateY(-8px)';
    setTimeout(function() {
      el.textContent = suggestions[idx];
      idx = (idx + 1) % suggestions.length;
      el.style.transform = 'translateY(8px)';
      el.offsetHeight;
      el.style.opacity = '1';
      el.style.transform = 'translateY(0)';
    }, 400);
  }
  el.textContent = suggestions[0];
  el.style.opacity = '1';
  idx = 1;
  setInterval(show, 3500);
  input.addEventListener('input', function() { ph.style.opacity = input.value.length > 0 ? '0' : '1'; });
  input.addEventListener('focus', function() { ph.style.opacity = '0'; });
  input.addEventListener('blur', function() { if (input.value.length === 0) ph.style.opacity = '1'; });
})();

// Glassmorphic header — solidify on scroll
(function() {
  var header = document.getElementById('home-header');
  if (!header) return;
  var scrolled = false;
  function check() {
    var isScrolled = window.scrollY > 40;
    if (isScrolled !== scrolled) {
      scrolled = isScrolled;
      if (scrolled) {
        header.style.background = 'rgba(250,250,250,0.85)';
        header.style.backdropFilter = 'blur(20px)';
        header.style.webkitBackdropFilter = 'blur(20px)';
        header.style.borderBottom = '1px solid rgba(0,0,0,0.06)';
      } else {
        header.style.background = 'transparent';
        header.style.backdropFilter = 'none';
        header.style.webkitBackdropFilter = 'none';
        header.style.borderBottom = '1px solid transparent';
      }
    }
  }
  check();
  window.addEventListener('scroll', check, { passive: true });
})();

// Mobile menu
document.getElementById('mobile-menu-btn').addEventListener('click', function() {
  document.getElementById('mobile-menu').classList.toggle('hidden');
});

// Scroll-triggered fade-in
(function() {
  var observer = new IntersectionObserver(function(entries) {
    entries.forEach(function(entry) {
      if (entry.isIntersecting) {
        entry.target.style.opacity = '1';
        entry.target.style.transform = 'translateY(0)';
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.05 });
  document.querySelectorAll('[data-animate]').forEach(function(el) {
    el.style.opacity = '0';
    el.style.transform = 'translateY(20px)';
    el.style.transition = 'opacity 0.6s ease-out, transform 0.6s ease-out';
    observer.observe(el);
  });
})();
</script>
