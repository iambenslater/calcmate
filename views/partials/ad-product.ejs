<%
// Sidebar product recommendations — clean editorial style (no ad-like borders/colours)
// Data passed via res.locals from server.js
const affiliateTag = 'benslater-22';

let products = [];
let affiliateCtx = 'general';
try {
  const productData = typeof affiliateProducts !== 'undefined' ? affiliateProducts : { products: {} };
  affiliateCtx = typeof calc !== 'undefined' ? (calc.affiliateContext || calc.category || 'general')
    : (typeof affiliateContext !== 'undefined' ? affiliateContext : 'general');
  products = (productData.products && productData.products[affiliateCtx]) || [];
  if (!products.length) products = productData.products['general'] || [];

  // Load click stats — boost products with higher CTR
  const stats = typeof affiliateStats !== 'undefined' ? affiliateStats : {};
  if (stats.byProduct) {
    products = products.map(p => {
      const s = stats.byProduct[p.asin];
      return { ...p, clicks: s ? s.clicks : 0 };
    });
    products.sort((a, b) => (b.clicks - a.clicks) || ((b.rating || 0) - (a.rating || 0)));
  }

  // Skip the first product (shown as "Our Pick" inline) — show next 2-3
  products = products.slice(1, 4);
} catch(e) {
  products = [];
}

function productUrl(p) {
  if (p.asin && p.asin.length >= 10) {
    return 'https://www.amazon.com.au/dp/' + p.asin + '?tag=' + affiliateTag;
  }
  return 'https://www.amazon.com.au/s?k=' + encodeURIComponent(p.searchFallback || p.title) + '&tag=' + affiliateTag;
}

function formatReviewCount(n) {
  if (!n) return '';
  if (n >= 1000) return (n / 1000).toFixed(n >= 10000 ? 0 : 1).replace(/\.0$/, '') + 'K';
  return String(n);
}
%>
<% if (products.length > 0) { %>
<div class="mt-1">
  <div class="flex items-center gap-2 mb-3">
    <div class="w-6 border-t border-gray-200"></div>
    <span class="text-[10px] text-gray-400 font-medium uppercase tracking-wider">Worth a look</span>
    <div class="flex-1 border-t border-gray-200"></div>
  </div>
  <div class="space-y-4">
    <% products.forEach((p, idx) => { %>
      <a href="<%- productUrl(p) %>" target="_blank" rel="nofollow noopener" class="flex items-start gap-3 group" data-affiliate-product="<%= p.asin %>" data-affiliate-position="<%= idx + 1 %>">
        <% if (p.image) { %>
        <div class="shrink-0 w-14 h-14 bg-white rounded-lg border border-gray-100 flex items-center justify-center p-1.5">
          <img src="<%= p.image %>" alt="<%= p.title %>" class="max-w-full max-h-full object-contain" loading="lazy">
        </div>
        <% } %>
        <div class="flex-1 min-w-0">
          <div class="text-sm font-medium text-gray-900 group-hover:text-blue-700 transition leading-snug"><%= p.title %></div>
          <div class="flex items-center flex-wrap gap-x-2 gap-y-0.5 mt-1">
            <% if (p.price) { %><span class="text-sm font-bold text-gray-900"><%= p.price %></span><% } %>
            <% if (p.rating) { %>
              <span class="text-xs text-gray-400"><%= p.rating %><span class="text-amber-500 ml-0.5"><%= '★'.repeat(Math.round(p.rating)) %></span><% if (p.reviewCount) { %> (<%= formatReviewCount(p.reviewCount) %>)<% } %></span>
            <% } %>
          </div>
          <span class="text-xs text-blue-600 group-hover:text-blue-800 transition mt-1 inline-block">Check price</span>
        </div>
      </a>
    <% }) %>
  </div>
  <p class="text-[9px] text-gray-300 mt-3">We may earn a commission at no extra cost to you.</p>
</div>
<% } %>
