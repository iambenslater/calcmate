<header class="bg-white/95 backdrop-blur-xl border-b border-black/5 sticky top-0 z-50">
  <div class="max-w-6xl mx-auto px-5 sm:px-8">
    <div class="flex items-center justify-between h-16">
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2.5 text-lg font-bold text-gray-900 hover:opacity-70 transition-opacity">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" class="w-7 h-7"><rect width="32" height="32" rx="6" fill="#393F23"/><rect x="5" y="5" width="22" height="22" rx="3" fill="#BFA956"/><rect x="8" y="8" width="16" height="5" rx="1" fill="#393F23" opacity="0.9"/><rect x="8" y="15" width="4" height="4" rx="0.5" fill="#393F23" opacity="0.7"/><rect x="14" y="15" width="4" height="4" rx="0.5" fill="#393F23" opacity="0.7"/><rect x="20" y="15" width="4" height="4" rx="0.5" fill="#393F23" opacity="0.7"/><rect x="8" y="21" width="4" height="4" rx="0.5" fill="#393F23" opacity="0.7"/><rect x="14" y="21" width="4" height="4" rx="0.5" fill="#393F23" opacity="0.7"/><rect x="20" y="21" width="4" height="4" rx="0.5" fill="#BFA956" stroke="#393F23" stroke-width="0.5"/><text x="24" y="24.5" font-size="4" font-weight="bold" fill="#393F23" text-anchor="middle" font-family="sans-serif">=</text></svg>
        <span>Calculator<span style="color: #BFA956">Mate</span></span>
      </a>

      <!-- Nav links (desktop) -->
      <nav class="hidden md:flex items-center gap-1">
        <a href="/articles" class="px-3.5 py-2 rounded-lg text-sm text-gray-600 hover:text-gray-900 hover:bg-black/5 transition-all duration-200 font-medium">Articles</a>
        <a href="/for" class="px-3.5 py-2 rounded-lg text-sm text-gray-600 hover:text-gray-900 hover:bg-black/5 transition-all duration-200 font-medium">Calculators For...</a>
        <div class="relative group">
          <button class="px-3.5 py-2 rounded-lg text-sm text-gray-600 hover:text-gray-900 hover:bg-black/5 transition-all duration-200 font-medium flex items-center gap-1">
            Categories
            <svg class="w-3.5 h-3.5 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
          </button>
          <div class="absolute right-0 top-full mt-1 w-64 bg-white/95 backdrop-blur-xl rounded-2xl cm-shadow-lg hidden group-hover:block z-50 border border-black/5 py-2">
            <% Object.entries(categoryMeta).forEach(([key, meta]) => { %>
              <a href="/<%= key %>" class="block px-4 py-2 hover:bg-black/5 transition text-sm text-gray-600 hover:text-gray-900"><span class="mr-2"><%= meta.icon %></span><%= meta.name %></a>
            <% }) %>
          </div>
        </div>
      </nav>

      <!-- Search (desktop) -->
      <div class="hidden md:block">
        <div class="relative">
          <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input type="search" id="search-input" placeholder="Search calculators..." class="w-48 pl-9 pr-3 py-2 rounded-xl bg-black/5 border-0 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-black/10 focus:w-64 transition-all duration-300" autocomplete="off">
          <div id="search-results" class="absolute top-full right-0 mt-2 w-80 bg-white rounded-2xl cm-shadow-lg text-gray-800 hidden max-h-96 overflow-y-auto z-50 border border-black/5"></div>
        </div>
      </div>

      <!-- Mobile menu button -->
      <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-black/5 transition">
        <svg class="w-5 h-5 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-white/95 backdrop-blur-xl border-t border-black/5">
    <div class="px-5 py-4 space-y-1">
      <!-- Mobile search -->
      <div class="relative mb-3">
        <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
        <input type="search" id="search-input-mobile" placeholder="Search calculators..." class="w-full pl-9 pr-3 py-2.5 rounded-xl bg-black/5 border-0 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-black/10" autocomplete="off">
        <div id="search-results-mobile" class="absolute top-full left-0 right-0 mt-1 bg-white rounded-2xl cm-shadow-lg text-gray-800 hidden max-h-64 overflow-y-auto z-50 border border-black/5"></div>
      </div>
      <a href="/articles" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-black/5 transition">Articles</a>
      <a href="/for" class="block px-3 py-2.5 rounded-lg text-sm font-medium text-gray-700 hover:bg-black/5 transition">Calculators For...</a>
      <div class="border-t border-black/5 pt-2 mt-2">
        <% Object.entries(categoryMeta).forEach(([key, meta]) => { %>
          <a href="/<%= key %>" class="block px-3 py-2 rounded-lg text-sm text-gray-600 hover:bg-black/5 transition">
            <span class="mr-2"><%= meta.icon %></span><%= meta.name %>
          </a>
        <% }) %>
      </div>
    </div>
  </div>
</header>

<script>
  document.getElementById('mobile-menu-btn').addEventListener('click', () => {
    document.getElementById('mobile-menu').classList.toggle('hidden');
  });
</script>
