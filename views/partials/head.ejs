<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Free Australian calculators for tax, mortgage, health, and more.' %>">
  <link rel="canonical" href="<%= siteUrl %><%= currentPath === '/' ? '' : currentPath %>">
  <meta name="robots" content="index, follow">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : '' %>">
  <meta property="og:type" content="<%= (typeof calc !== 'undefined' || typeof article !== 'undefined') ? 'article' : 'website' %>">
  <meta property="og:url" content="<%= siteUrl %><%= currentPath === '/' ? '' : currentPath %>">
  <meta property="og:site_name" content="CalculatorMate Australia">
  <% const ogImage = (typeof calc !== 'undefined' && calc) ? `${siteUrl}/og/${calc.category}/${calc.slug}.png` : `${siteUrl}/images/og-default.png`; %>
  <meta property="og:image" content="<%= ogImage %>">
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="<%= title %>">
  <meta name="twitter:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : '' %>">
  <meta name="twitter:image" content="<%= ogImage %>">
  <meta name="commission-factory-verification" content="f6ed4bf9fea54bd4bad3f19f02009f37">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.svg">
  <meta name="theme-color" content="#393F23">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/tailwind.css?v=20260413b">
  <link rel="stylesheet" href="/css/style.css?v=20260413b">
  <script src="/js/affiliate-tracking.js" defer></script>
  <!-- Google AdSense -->
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-8414007005923504" crossorigin="anonymous"></script>
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XHWH23NHN8"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XHWH23NHN8');
  </script>
</head>
<body class="bg-[#FAFAF6] font-sans text-gray-800 min-h-screen flex flex-col">
