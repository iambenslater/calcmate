<!DOCTYPE html>
<html lang="en-AU">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : 'Free Australian calculators for tax, mortgage, health, and more.' %>">
  <link rel="canonical" href="<%= siteUrl %><%= currentPath === '/' ? '' : currentPath %>">
  <meta name="robots" content="index, follow">
  <meta property="og:title" content="<%= title %>">
  <meta property="og:description" content="<%= typeof metaDescription !== 'undefined' ? metaDescription : '' %>">
  <meta property="og:type" content="website">
  <meta property="og:url" content="<%= siteUrl %><%= currentPath %>">
  <meta property="og:site_name" content="CalculatorMate Australia">
  <meta name="twitter:card" content="summary">
  <meta name="commission-factory-verification" content="f6ed4bf9fea54bd4bad3f19f02009f37">
  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon.svg">
  <meta name="theme-color" content="#00205B">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <script>
    tailwind.config = {
      theme: {
        extend: {
          colors: {
            navy: '#00205B',
            gold: '#FFB800',
            'gold-light': '#FFF3D0'
          },
          fontFamily: {
            sans: ['Inter', 'system-ui', 'sans-serif']
          }
        }
      }
    }
  </script>
  <link rel="stylesheet" href="/css/style.css">
  <% if (typeof calc !== 'undefined' && calc.slug) { %>
  <script defer src="https://cdn.jsdelivr.net/npm/chart.js@4.4.4/dist/chart.umd.min.js"></script>
  <% } %>
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-XHWH23NHN8"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-XHWH23NHN8');
  </script>
</head>
<body class="bg-gray-50 font-sans text-gray-800 min-h-screen flex flex-col">
