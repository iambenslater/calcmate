<%
const affiliateTag = 'benslater-22';
const adIndex = typeof adSlot !== 'undefined' ? adSlot : 0;

// Determine context
const leaderCtx = typeof calc !== 'undefined' ? (calc.affiliateContext || calc.category || 'general')
  : (typeof affiliateContext !== 'undefined' ? affiliateContext : 'general');

// Try to get a curated product for this slot
const productData = typeof affiliateProducts !== 'undefined' ? affiliateProducts : { products: {} };
const ctxProducts = (productData.products && productData.products[leaderCtx]) || productData.products['general'] || [];

// Pick a different product for each ad slot on the page
const leaderProduct = ctxProducts.length > 0 ? ctxProducts[adIndex % ctxProducts.length] : null;

// Gradient colours per context (keeps the visual variety)
const gradients = {
  budgeting: 'from-amber-500 to-orange-500',
  'tax-software': 'from-blue-600 to-indigo-600',
  'health-insurance': 'from-emerald-500 to-teal-500',
  'office-furniture': 'from-gray-700 to-gray-900',
  education: 'from-purple-500 to-indigo-500',
  'finance-books': 'from-green-600 to-emerald-600',
  savings: 'from-amber-500 to-yellow-500',
  mortgage: 'from-blue-600 to-indigo-700',
  investment: 'from-green-500 to-teal-500',
  'home-tools': 'from-orange-500 to-red-500',
  fitness: 'from-cyan-500 to-blue-500',
  baby: 'from-pink-400 to-rose-400',
  general: 'from-navy to-blue-800',
  'car-accessories': 'from-gray-800 to-gray-900',
  'car-loan': 'from-slate-700 to-gray-900',
  travel: 'from-sky-500 to-blue-500',
  'office-supplies': 'from-slate-600 to-slate-800',
  kitchen: 'from-amber-600 to-orange-600',
  food: 'from-green-500 to-emerald-500',
  'business-books': 'from-navy to-indigo-800',
  'home-appliances': 'from-green-500 to-emerald-500',
  'trade-tools': 'from-yellow-600 to-amber-700',
  health: 'from-red-500 to-rose-600',
  'credit-cards': 'from-indigo-600 to-purple-600',
  'personal-loan': 'from-blue-500 to-indigo-600',
  insurance: 'from-slate-600 to-gray-800',
  pet: 'from-orange-400 to-amber-500',
  fashion: 'from-pink-500 to-purple-500'
};
const bg = gradients[leaderCtx] || gradients.general;

function leaderUrl(p) {
  if (p && p.asin && p.asin.length >= 10) {
    return 'https://www.amazon.com.au/dp/' + p.asin + '?tag=' + affiliateTag;
  }
  if (p && p.searchFallback) {
    return 'https://www.amazon.com.au/s?k=' + encodeURIComponent(p.searchFallback) + '&tag=' + affiliateTag;
  }
  return 'https://www.amazon.com.au/?tag=' + affiliateTag;
}
%>
<% if (leaderProduct) { %>
<a href="<%- leaderUrl(leaderProduct) %>" target="_blank" rel="nofollow noopener" class="block rounded-lg overflow-hidden bg-gradient-to-r <%= bg %> text-white hover:opacity-90 transition shadow-sm" data-affiliate-product="<%= leaderProduct.asin %>">
  <div class="flex items-center justify-between px-5 py-3 gap-3">
    <div class="min-w-0 flex-1">
      <div class="font-bold text-sm md:text-base truncate"><%= leaderProduct.title %></div>
      <div class="flex items-center gap-2 mt-0.5">
        <% if (leaderProduct.price) { %><span class="text-xs font-semibold opacity-90"><%= leaderProduct.price %></span><% } %>
        <% if (leaderProduct.rating) { %><span class="text-xs opacity-75"><%= '★'.repeat(Math.round(leaderProduct.rating)) %> <%= leaderProduct.rating %></span><% } %>
        <span class="text-[10px] opacity-60">· Amazon.com.au</span>
      </div>
    </div>
    <div class="bg-white text-gray-900 px-4 py-1.5 rounded-full text-xs font-bold whitespace-nowrap hover:bg-gray-100 transition shrink-0">
      View Deal →
    </div>
  </div>
</a>
<% } else { %>
<a href="https://www.amazon.com.au/?tag=<%= affiliateTag %>" target="_blank" rel="nofollow noopener" class="block rounded-lg overflow-hidden bg-gradient-to-r from-navy to-blue-800 text-white hover:opacity-90 transition shadow-sm">
  <div class="flex items-center justify-between px-5 py-3">
    <div>
      <div class="font-bold text-sm md:text-base">Tools That Make Life Easier</div>
      <div class="text-[10px] opacity-75 mt-0.5">Sponsored · Amazon.com.au</div>
    </div>
    <div class="bg-white text-gray-900 px-4 py-1.5 rounded-full text-xs font-bold whitespace-nowrap hover:bg-gray-100 transition">
      Shop on Amazon →
    </div>
  </div>
</a>
<% } %>
