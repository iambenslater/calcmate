<nav aria-label="Breadcrumb" class="mb-4">
  <ol class="flex items-center gap-2 text-sm text-gray-500">
    <li><a href="/" class="hover:text-gray-900 transition-colors duration-200">Home</a></li>
    <% if (typeof category !== 'undefined') { %>
      <li class="text-gray-300">/</li>
      <li><a href="/<%= category %>" class="hover:text-gray-900 transition-colors duration-200"><%= categoryName %></a></li>
    <% } %>
    <% if (typeof calc !== 'undefined') { %>
      <li class="text-gray-300">/</li>
      <li class="text-gray-700 font-medium"><%= calc.title %></li>
    <% } %>
  </ol>
</nav>
