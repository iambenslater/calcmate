      <!-- Categories — all dynamically listed -->
      <div>
        <h4 class="text-white/80 font-semibold mb-4 text-sm">Categories</h4>
        <ul class="space-y-2 text-sm">
          <% Object.entries(categoryMeta).forEach(([key, meta]) => { %>
            <li><a href="/<%= key %>" class="hover:text-white transition-colors duration-200"><%= meta.name %></a></li>
          <% }) %>
