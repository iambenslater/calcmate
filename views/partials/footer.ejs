        <p class="text-sm leading-relaxed">173 free online calculators built for Australians with current rates and state-specific data.</p>
      </div>

      <!-- Popular -->
      <div>
        <h4 class="text-white/80 font-semibold mb-4 text-sm">Popular</h4>
        <ul class="space-y-2.5 text-sm">
          <li><a href="/finance/take-home-pay" class="hover:text-white transition-colors duration-200">Take Home Pay</a></li>
          <li><a href="/property/mortgage-repayment" class="hover:text-white transition-colors duration-200">Mortgage Repayment</a></li>
          <li><a href="/health/bmi" class="hover:text-white transition-colors duration-200">BMI Calculator</a></li>
          <li><a href="/conversions/gst-calculator" class="hover:text-white transition-colors duration-200">GST Calculator</a></li>
          <li><a href="/conversions/percentage" class="hover:text-white transition-colors duration-200">Percentage</a></li>
        </ul>
