<%
const affiliateTag = 'benslater-22';

// Load curated product for this context — show the #1 pick as the inline CTA
// Data passed via res.locals from server.js (no require() in EJS)
let inlineProduct = null;
let affiliateCtx = 'general';
try {
  const productData = typeof affiliateProducts !== 'undefined' ? affiliateProducts : { products: {} };
  affiliateCtx = typeof calc !== 'undefined' ? (calc.affiliateContext || calc.category || 'general')
    : (typeof affiliateContext !== 'undefined' ? affiliateContext : 'general');
  const products = (productData.products && productData.products[affiliateCtx]) || productData.products['general'] || [];
  if (products.length) inlineProduct = products[0];
} catch(e) { /* no product data */ }

// Fallback labels by context
const contextLabels = {
  food: 'Meal Prep Essentials',
  fitness: 'Smart Body Tracking',
  'finance-books': "Australia's Best Finance Books",
  'tax-software': 'Tax Season Essentials',
  budgeting: 'Budget Planning Tools',
  mortgage: 'First Home Buyer Guides',
  savings: 'Savings & Investing',
  investment: 'Investing Starter Kit',
  'car-accessories': 'Dash Cams for Australian Roads',
  'car-loan': 'New Car Essentials',
  'trade-tools': 'Professional Trade Tools',
  'home-appliances': 'Energy Saving Gadgets',
  'home-tools': 'Home Improvement Essentials',
  kitchen: 'Kitchen Precision Tools',
  baby: 'New Parent Must-Haves',
  education: 'Study Essentials',
  fashion: 'Body Measurement Tools',
  travel: 'Travel Packing Essentials',
  'business-books': 'Small Business Books',
  'office-furniture': 'Work From Home Upgrade',
  'office-supplies': 'Office Desk Tools',
  pet: 'Pet Care Essentials',
  insurance: 'Document Protection',
  health: 'Health Monitoring at Home',
  'health-insurance': 'Health Tracking Essentials',
  'credit-cards': 'Debt Freedom Tools',
  'personal-loan': 'Financial Planning Tools',
  general: 'Best-Selling on Amazon'
};

const label = contextLabels[affiliateCtx] || contextLabels.general;

function inlineUrl() {
  if (inlineProduct && inlineProduct.asin && inlineProduct.asin.length >= 10) {
    return 'https://www.amazon.com.au/dp/' + inlineProduct.asin + '?tag=' + affiliateTag;
  }
  if (inlineProduct && inlineProduct.searchFallback) {
    return 'https://www.amazon.com.au/s?k=' + encodeURIComponent(inlineProduct.searchFallback) + '&tag=' + affiliateTag;
  }
  return 'https://www.amazon.com.au/?tag=' + affiliateTag;
}
%>
<% if (inlineProduct) { %>
<div class="bg-gold-light rounded-xl p-5 mb-8 border border-gold/30">
  <div class="flex items-start gap-4">
    <div class="text-3xl">🛒</div>
    <div class="flex-1">
      <h3 class="font-bold text-navy text-sm mb-1"><%= label %></h3>
      <p class="text-sm text-gray-800 font-medium"><%= inlineProduct.title %> — <%= inlineProduct.price %></p>
      <p class="text-xs text-gray-600 mb-3"><%= inlineProduct.tagline %><% if (inlineProduct.rating) { %> · <span class="text-amber-500"><%= '★'.repeat(Math.round(inlineProduct.rating)) %></span> <%= inlineProduct.rating %><% } %></p>
      <a href="<%- inlineUrl() %>" target="_blank" rel="nofollow noopener" class="inline-block px-4 py-2 bg-gold text-navy text-xs font-bold rounded-lg hover:bg-yellow-400 transition">
        View on Amazon →
      </a>
    </div>
  </div>
  <p class="text-[10px] text-gray-400 mt-2">As an Amazon Associate, CalculatorMate earns from qualifying purchases.</p>
</div>
<% } %>
